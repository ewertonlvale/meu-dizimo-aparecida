function testarConversaoPDF() {
  console.log('🧪 Testando conversão PDF...');
  
  try {
    // 1. Criar um PDF de teste
    const pdfContent = 'https://drive.google.com/file/d/1ctNwahKIT3VF7jCjigGX69hPT-mP87OZ/view?usp=sharing';
    const pdfBlob = Utilities.newBlob(pdfContent, 'application/pdf', 'teste.pdf');
    
    // 2. Salvar no Drive
    const pdfFile = DriveApp.getRootFolder().createFile(pdfBlob);
    const pdfId = pdfFile.getId();
    console.log('✅ PDF criado no Drive:', pdfId);
    
    // 3. Tentar converter
    Utilities.sleep(1000);
    
    const exportUrl = `https://www.googleapis.com/drive/v3/files/${pdfId}/export?mimeType=image/png`;
    const response = UrlFetchApp.fetch(exportUrl, {
      method: 'get',
      headers: { Authorization: `Bearer ${ScriptApp.getOAuthToken()}` },
      muteHttpExceptions: true
    });
    
    const statusCode = response.getResponseCode();
    console.log('📥 Status da conversão:', statusCode);
    
    // 4. Deletar arquivo
    pdfFile.setTrashed(true);
    console.log('🗑️ PDF deletado');
    
    if (statusCode === 200) {
      console.log('✅ SUCESSO! Conversão funcionou!');
      return true;
    } else {
      console.error('❌ ERRO:', response.getContentText());
      return false;
    }
    
  } catch (e) {
    console.error('❌ Exceção:', e.message);
    console.error('Stack:', e.stack);
    return false;
  }
}

// ============================================================================
// DIAGNÓSTICO COMPLETO
// ============================================================================

/**
 * Executa todos os testes e exibe um relatório consolidado.
 * Execute esta função para verificar se o sistema está operacional.
 */
function diagnostico() {
  Logger.log('\n');
  Logger.log('═'.repeat(50));
  Logger.log('  🤖 BOT MEU DÍZIMO – DIAGNÓSTICO COMPLETO');
  Logger.log('═'.repeat(50));
  Logger.log(`  Data:   ${new Date().toLocaleString('pt-BR')}`);
  Logger.log(`  Número: ${NUMERO_TESTE || '⚠️ não configurado'}`);
  Logger.log('═'.repeat(50));

  // Testes que não exigem NUMERO_TESTE
  const resultados = {};
  resultados['Configurações']     = testarConfig();
  resultados['Avatar (Drive)']    = testarAvatar();
  resultados['Boas-Vindas']        = NUMERO_TESTE ? testarBoasVindas() : null;
  resultados['Odoo']              = testarOdoo();
  resultados['Google Vision']     = testarVision();

  // Testes que exigem NUMERO_TESTE
  if (NUMERO_TESTE) {
    resultados['Menu Principal']  = testarMenuPrincipal();
    resultados['Ser Dizimista']   = testarSerDizimista();
    resultados['Já sou Dizimista']= testarSouDizimista();
    resultados['Devolver Dízimo'] = testarDevolverDizimo();
    resultados['Histórico']       = testarHistorico();
    resultados['Secretaria']      = testarSecretaria();
  }

  Logger.log('\n' + '═'.repeat(50));
  Logger.log('  📊 RESUMO');
  Logger.log('═'.repeat(50));

  let totalOk  = 0;
  let totalErr = 0;

  Object.entries(resultados).forEach(([nome, resultado]) => {
    if (resultado === null) {
      Logger.log(`  ⚪ ${nome}: PULADO`);
    } else if (resultado) {
      Logger.log(`  ✅ ${nome}`);
      totalOk++;
    } else {
      Logger.log(`  ❌ ${nome}`);
      totalErr++;
    }
  });

  if (!NUMERO_TESTE) {
    Logger.log('  ⚪ Menu Principal       } PULADOS');
    Logger.log('  ⚪ Ser Dizimista        } Configure NUMERO_TESTE');
    Logger.log('  ⚪ Já sou Dizimista     } nas Script Properties');
    Logger.log('  ⚪ Devolver Dízimo      } para executar');
    Logger.log('  ⚪ Histórico            } estes testes');
    Logger.log('  ⚪ Secretaria           }');
  }

  Logger.log('═'.repeat(50));
  Logger.log(`  Total: ${totalOk} OK | ${totalErr} com erro`);
  Logger.log('═'.repeat(50));

  if (totalErr === 0) {
    Logger.log('\n  🎉 Sistema pronto para uso!');
  } else {
    Logger.log('\n  ⚠️ Corrija os erros antes de implantar em produção.');
    Logger.log('  Execute setupProperties() se necessário.');
  }
  Logger.log('');
}

// ============================================================================
// UTILITÁRIOS DE DEBUG
// ============================================================================

/** Limpa o estado e dados temporários do NUMERO_TESTE no cache. */
function limparEstadoTeste() {
  if (!_exigirNumeroTeste()) return;
  StateManager.limparDados(NUMERO_TESTE);
  Logger.log(`✅ Estado limpo para ${NUMERO_TESTE}`);
}

/** Exibe o estado atual e dados temporários do NUMERO_TESTE. */
function verEstadoAtual() {
  if (!_exigirNumeroTeste()) return;
  const estado = StateManager.getEstado(NUMERO_TESTE);
  const dados  = StateManager.getDadosTemporarios(NUMERO_TESTE);

  Logger.log(`\n📊 Estado de ${NUMERO_TESTE}:`);
  Logger.log(`   Estado: ${estado}`);
  Logger.log(`   Dados:  ${JSON.stringify(dados, null, 2)}`);
}

// ============================================================================
// HELPERS INTERNOS
// ============================================================================

/** Verifica se NUMERO_TESTE está configurado. Loga aviso e retorna false se não. */
function _exigirNumeroTeste() {
  if (!NUMERO_TESTE) {
    Logger.log('⚠️ Configure NUMERO_TESTE nas Script Properties para executar este teste.');
    return false;
  }
  return true;
}
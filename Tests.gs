      Logger.log(`✅ Dizimista encontrado:`);
      Logger.log(`   Nome:      ${dizimista.x_name}`);
      Logger.log(`   Completo:  ${dizimista.x_studio_nome_completo}`);
      Logger.log(`   WhatsApp:  ${dizimista.x_studio_partner_phone}`);
      Logger.log(`   Valor:     R$ ${dizimista.x_studio_value}`);
    } else {
      Logger.log(`ℹ️ Nenhum dizimista encontrado para ${NUMERO_TESTE}`);
      Logger.log(`   (Isso é esperado se o número não estiver cadastrado)`);
    }
    return true;

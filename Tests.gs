/**
 * Envia o avatar via URL do Drive + mensagem de boas-vindas completa.
 * Replica exatamente o fluxo real do Webhook no primeiro contato.
 * ⚠️  Requer NUMERO_TESTE e ASSETS.AVATAR_DRIVE_ID configurados.
 */
function testarBoasVindas() {
  Logger.log('\n🔍 TESTE: Boas-Vindas (avatar + mensagem)\n' + '━'.repeat(40));

  if (!_exigirNumeroTeste()) return false;

  try {
    const driveId = ASSETS.AVATAR_DRIVE_ID;

    if (!driveId || driveId.startsWith('COLE_AQUI')) {
      Logger.log('❌ ASSETS.AVATAR_DRIVE_ID não configurado em Assets.gs.');
      return false;
    }

    Logger.log('   Drive ID: ' + driveId);

    // 1. Enviar avatar via URL pública do Drive
    Logger.log('   Passo 1/2: Enviando avatar...');
    const resultadoImagem = MediaService.enviarImagemDrive(
      NUMERO_TESTE,
      driveId,
      '👋 Olá! Eu sou a Cidinha!'
    );

    if (!resultadoImagem) {
      Logger.log('❌ Falha ao enviar imagem. Verifique:');
      Logger.log('   • O arquivo está compartilhado como "Qualquer pessoa com o link"?');
      Logger.log('   • O token e phone ID do WhatsApp estão corretos?');
      return false;
    }

    Logger.log('   ✅ Avatar enviado!');
    Utilities.sleep(2000);

    // 2. Enviar texto de boas-vindas + menu principal
    Logger.log('   Passo 2/2: Enviando mensagem de boas-vindas...');
    MenuHandler.boasVindas(NUMERO_TESTE);

    Logger.log(`\n✅ Boas-vindas enviadas com sucesso para ${NUMERO_TESTE}!`);
    Logger.log('   Verifique o WhatsApp: imagem → texto → menu principal.');
    return true;

  } catch (error) {
    Logger.log(`❌ Erro: ${error.message}`);
    Logger.log('Stack: ' + error.stack);
    return false;
  }
}


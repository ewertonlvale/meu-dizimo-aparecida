/**
 * ============================================================================
 * TESTS.GS - Bot Meu Dízimo
 * ============================================================================
 *
 * Funções de teste e diagnóstico. Execute manualmente no editor do Apps Script.
 *
 * FUNÇÕES DISPONÍVEIS:
 *
 *   — Infraestrutura —
 *   testarConfig()              → Verifica se todas as properties estão configuradas
 *   testarAvatar()              → Busca a imagem do avatar no Google Drive
 *
 *   — Integrações —
 *   testarOdoo()                → Testa conexão e lista comunidades do Odoo
 *   testarBuscarDizimista()     → Busca dizimista pelo NUMERO_TESTE
 *   testarVision()              → Testa OCR com imagem de amostra
 *
 *   — Menus e Fluxos —
 *   testarMenuPrincipal()       → Envia o menu principal
 *   testarSerDizimista()        → Inicia o fluxo de cadastro (btn_ser_dizimista)
 *   testarSouDizimista()        → Verifica cadastro e exibe opções (btn_ja_sou_dizimista)
 *   testarDevolverDizimo()      → Inicia fluxo de devolução (btn_devolver_dizimo)
 *   testarHistorico()           → Exibe histórico de devoluções (btn_minhas_devolucoes)
 *   testarSecretaria()          → Exibe informações da secretaria (btn_secretaria)
 *
 *   — Diagnóstico —
 *   diagnostico()               → Executa todos os testes e exibe relatório completo
 *
 *   — Debug —
 *   limparEstadoTeste()         → Limpa o cache do NUMERO_TESTE
 *   verEstadoAtual()            → Exibe estado e dados temporários do NUMERO_TESTE
 *
 * Versão: 8.0
 * Data: Fevereiro 2026
 */

// ============================================================================
// CONFIGURAÇÃO
// ============================================================================

const NUMERO_TESTE = PropertiesService.getScriptProperties().getProperty('NUMERO_TESTE') || '';

// ============================================================================
// INFRAESTRUTURA
// ============================================================================

function testarConfig() {
  Logger.log('\n🔍 TESTE: Configurações\n' + '━'.repeat(40));

  const chaves = [
    'WHATSAPP_TOKEN', 'WHATSAPP_PHONE_ID', 'VERIFY_TOKEN',
    'ODOO_URL', 'ODOO_DATABASE', 'ODOO_UID', 'ODOO_API_KEY',
    'GOOGLE_VISION_API_KEY'
  ];

  const props = PropertiesService.getScriptProperties();
  let ok = true;

  chaves.forEach(chave => {
    const valor = props.getProperty(chave);
    if (valor) {
      const exibir = chave.includes('KEY') || chave.includes('TOKEN')
        ? valor.substring(0, 8) + '...'
        : valor;
      Logger.log(`✅ ${chave}: ${exibir}`);
    } else {
      Logger.log(`❌ ${chave}: NÃO CONFIGURADA`);
      ok = false;
    }
  });

  Logger.log(ok ? '\n✅ Todas as configurações OK!' : '\n❌ Configure as propriedades faltantes via setupProperties().');
  return ok;
}

function testarAvatar() {
  Logger.log('\n🔍 TESTE: Avatar (Google Drive)\n' + '━'.repeat(40));

  try {
    const id = ASSETS.AVATAR_DRIVE_ID;

    if (!id || id.startsWith('COLE_AQUI')) {
      Logger.log('⚠️ ASSETS.AVATAR_DRIVE_ID não configurado em Assets.gs.');
      return false;
    }

    Logger.log(`   ID configurado: ${id}`);

    const base64 = getAvatar();

    if (!base64) {
      Logger.log('❌ getAvatar() retornou null.');
      Logger.log('   Verifique o ID e se o arquivo está compartilhado como "Qualquer pessoa com o link".');
      return false;
    }

    Logger.log(`✅ Avatar obtido com sucesso!`);
    Logger.log(`   Tamanho base64: ${base64.length} chars (~${Math.round(base64.length * 0.75 / 1024)} KB)`);
    return true;

  } catch (error) {
    Logger.log(`❌ Erro ao buscar avatar: ${error.message}`);
    Logger.log('   Verifique permissões do arquivo no Drive.');
    return false;
  }
}

